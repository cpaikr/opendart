{
  "name": "opendart-spec",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0 || >=20.19.0 <21.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "sync:opendart": "node scripts/sync-opendart.mjs",
    "probe:opendart-multi-company": "node scripts/probe-multi-company.mjs",
    "test:opendart": "node --test scripts/*.test.mjs",
    "check:opendart": "node scripts/check-opendart.mjs",
    "lint:opendart": "redocly lint openapi/openapi.yaml --config openapi/redocly.yaml --lint-config error --max-problems 1000",
    "bundle:opendart": "redocly bundle openapi/openapi.yaml --config openapi/redocly.yaml --output openapi/generated/openapi.bundle.yaml --component-renaming-conflicts-severity error",
    "check:opendart-bundle": "node scripts/check-opendart-bundle.mjs",
    "lint:opendart-bundle": "redocly lint openapi/generated/openapi.bundle.yaml --config openapi/redocly.yaml --lint-config error --max-problems 1000",
    "verify:opendart": "npm run test:opendart && npm run check:opendart && npm run lint:opendart && npm run check:opendart-bundle && npm run lint:opendart-bundle"
  },
  "devDependencies": {
    "@redocly/cli": "2.39.0",
    "cheerio": "1.2.0",
    "saxes": "6.0.0",
    "yaml": "2.9.0"
  }
}
